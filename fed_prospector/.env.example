# MySQL root password (used by fed_prospector.py service manager)
MYSQL_ROOT_PASS=changeme

# Database
MYSQL_BIN_DIR=E:\mysql\bin
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fed_contracts
DB_USER=fed_app
DB_PASSWORD=changeme
DB_POOL_SIZE=32

# SAM.gov API (expires every 90 days)
SAM_API_KEY=changeme
SAM_DAILY_LIMIT=10

# SAM.gov API key 2 (confirmed >10/day limit, likely 1000/day tier)
SAM_API_KEY_2=changeme
SAM_DAILY_LIMIT_2=1000

# Claude API Token
ANTHROPIC_API_KEY=changeme

# JWT secret for .NET API (min 32 chars, dev-only)
JWT_SECRET_KEY=changeme

# Directories
DATA_DIR=./data
ATTACHMENT_DIR=C:\fedprospector\attachments
LOG_LEVEL=INFO


# admin_account_test_info
admin_pass=