{
  "ConnectionStrings": {
    "DefaultConnection": "SET_VIA_ENVIRONMENT"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "FedProspector.Api",
    "Audience": "FedProspector.Client"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "SamApi": {
    "ApiKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/fedprospector-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "localhost"
}
