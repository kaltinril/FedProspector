{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=fed_contracts;User=fed_app;Password=YOUR_PASSWORD;SslMode=None;AllowPublicKeyRetrieval=True;MaxPoolSize=50;MinPoolSize=5"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARS"
  },
  "Cors": {
    "AllowedOrigins": ["https://your-public-hostname"]
  },
  "AllowedHosts": "your-public-hostname",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://0.0.0.0:5056",
        "Certificate": {
          "Path": "C:\\path\\to\\fedprospector.pfx",
          "Password": "YOUR_PFX_PASSWORD"
        }
      }
    }
  },
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/fedprospector-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}
